# Docker Compose
POSTGRES_PASSWORD=aigymos_dev
JWT_SECRET_KEY=replace-with-a-strong-secret
CPF_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Use a URL publica em producao. Para ambiente local, estes valores funcionam com o compose padrao.
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]
VITE_API_BASE_URL=http://localhost:8000
PUBLIC_BOOKING_RATE_LIMIT=10/hour
PUBLIC_WHATSAPP_WEBHOOK_RATE_LIMIT=30/minute
PUBLIC_OBJECTION_RESPONSE_RATE_LIMIT=5/hour
PUBLIC_PROPOSAL_RATE_LIMIT=5/hour
PUBLIC_OBJECTION_RESPONSE_ENABLED=false
PUBLIC_PROPOSAL_ENABLED=false
SCHEDULER_CRITICAL_LOCK_FAIL_OPEN=false
ACTUAR_SYNC_ENABLED=true
ACTUAR_BROWSER_HEADLESS=true
ACTUAR_SYNC_MAX_RETRIES=3
ACTUAR_SYNC_SCREENSHOT_ON_SUCCESS=false
ACTUAR_SYNC_SCREENSHOT_ON_FAILURE=true
ACTUAR_SYNC_TIMEOUT_SECONDS=60
ACTUAR_SYNC_REQUIRED_FOR_TRAINING=true
ACTUAR_SYNC_EVIDENCE_DIR=data/actuar-sync-evidence
ACTUAR_BASE_URL=
ACTUAR_USERNAME=
ACTUAR_PASSWORD=

# Opcional; se vazio, o frontend deriva ws:// / wss:// a partir de VITE_API_BASE_URL.
VITE_WS_BASE_URL=
