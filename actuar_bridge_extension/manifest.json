{
  "manifest_version": 3,
  "name": "Cordex Gym OS Actuar Bridge",
  "version": "0.1.0",
  "description": "Anexa a aba do Actuar e executa jobs locais da ponte do Cordex Gym OS.",
  "permissions": ["activeTab", "tabs", "storage", "alarms", "scripting"],
  "host_permissions": [
    "http://127.0.0.1:44777/*",
    "https://app.actuar.com/*",
    "https://*.actuar.com/*",
    "https://*.actuar.cloud/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Actuar Bridge",
    "default_popup": "popup.html"
  }
}
