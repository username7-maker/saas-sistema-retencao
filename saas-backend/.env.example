# Core
ENVIRONMENT=development
DEBUG=true
# Em producao, mantenha false na API e rode `python -m app.worker` separadamente.
ENABLE_SCHEDULER=false
ENABLE_SCHEDULER_IN_API=false
SCHEDULER_CRITICAL_LOCK_FAIL_OPEN=false
APP_NAME=AI GYM OS
API_PREFIX=/api/v1
# Para compose/producao, substitua pela URL publica do frontend.
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
# URL usada em links do backend (ex.: reset de senha). Em producao, use a URL publica do frontend.
FRONTEND_URL=http://localhost:5173

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/aigymos

# Auth
JWT_SECRET_KEY=change-this-super-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# CPF AES-256 (64 hex chars OR base64 32-byte key)
CPF_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Integrations
SENDGRID_API_KEY=
SENDGRID_SENDER=noreply@aigymos.com
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-haiku-latest
CLAUDE_VISION_MODEL=claude-3-5-sonnet-latest
CLAUDE_MAX_TOKENS=250
BODY_COMPOSITION_IMAGE_AI_ENABLED=false
BODY_COMPOSITION_IMAGE_AI_TIMEOUT_SECONDS=20
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
PUBLIC_BACKEND_URL=
WHATSAPP_INSTANCE=default
WHATSAPP_ALLOW_GLOBAL_FALLBACK=false
WHATSAPP_RATE_LIMIT_PER_HOUR=6
WHATSAPP_WEBHOOK_TOKEN=
PUBLIC_DIAG_GYM_ID=
ADMIN_GYM_ID=
PUBLIC_BOOKING_URL=https://cal.com/aigymos
PUBLIC_DIAG_RATE_LIMIT=5/hour
PUBLIC_BOOKING_RATE_LIMIT=10/hour
PUBLIC_WHATSAPP_WEBHOOK_RATE_LIMIT=30/minute
PUBLIC_OBJECTION_RESPONSE_RATE_LIMIT=5/hour
PUBLIC_PROPOSAL_RATE_LIMIT=5/hour
PUBLIC_OBJECTION_RESPONSE_ENABLED=false
PUBLIC_PROPOSAL_ENABLED=false
ACTUAR_SYNC_ENABLED=true
ACTUAR_BROWSER_HEADLESS=true
ACTUAR_SYNC_MAX_RETRIES=3
ACTUAR_SYNC_SCREENSHOT_ON_SUCCESS=false
ACTUAR_SYNC_SCREENSHOT_ON_FAILURE=true
ACTUAR_SYNC_TIMEOUT_SECONDS=60
ACTUAR_SYNC_REQUIRED_FOR_TRAINING=true
ACTUAR_SYNC_EVIDENCE_DIR=data/actuar-sync-evidence
ACTUAR_BASE_URL=
ACTUAR_USERNAME=
ACTUAR_PASSWORD=
ACTUAR_SYNC_MODE=assisted_rpa
ACTUAR_BRIDGE_POLL_SECONDS=15
ACTUAR_BRIDGE_DEVICE_STALE_SECONDS=90
ACTUAR_BRIDGE_PAIRING_CODE_TTL_MINUTES=10

# Cache distribuido (opcional, recomendado para multi-instancia)
REDIS_URL=
DASHBOARD_CACHE_TTL_SECONDS=300
DASHBOARD_CACHE_MAXSIZE=512
