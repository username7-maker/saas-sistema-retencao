ENVIRONMENT=production
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME
REDIS_URL=redis://default:PASSWORD@HOST:PORT

JWT_SECRET_KEY=replace-with-a-strong-secret-with-32-plus-chars
CPF_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

FRONTEND_URL=https://your-project.vercel.app
CORS_ORIGINS=["https://your-project.vercel.app"]
PUBLIC_BACKEND_URL=https://your-backend.up.railway.app

ENABLE_SCHEDULER=false
ENABLE_SCHEDULER_IN_API=false
SCHEDULER_CRITICAL_LOCK_FAIL_OPEN=false

SENDGRID_API_KEY=
SENDGRID_SENDER=

WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_INSTANCE=default
WHATSAPP_WEBHOOK_TOKEN=

PUBLIC_OBJECTION_RESPONSE_ENABLED=false
PUBLIC_PROPOSAL_ENABLED=false

ACTUAR_ENABLED=false
ACTUAR_SYNC_ENABLED=false
ACTUAR_SYNC_MODE=disabled
ACTUAR_BASE_URL=
ACTUAR_USERNAME=
ACTUAR_PASSWORD=

CLAUDE_API_KEY=
BODY_COMPOSITION_IMAGE_AI_ENABLED=false
