# Cordex WhatsApp AI Agent V1 - n8n placeholders

N8N_BASE_URL=https://n8n.example.com
N8N_WHATSAPP_AGENT_WEBHOOK_URL=https://n8n.example.com/webhook/cordex-whatsapp-agent
DEFAULT_WORKSPACE_ID=cordex-internal

CORDEX_AGENT_SERVICE_TOKEN=replace_with_random_long_service_token
WHATSAPP_AGENT_MODE=sandbox
WHATSAPP_INTERNAL_ALLOWED_PHONES=5511000000000,5511999999999
WHATSAPP_EXTERNAL_AUTO_REPLY_ENABLED=true
WHATSAPP_AGENT_FALLBACK_TO_LEGACY_NURTURING=true

OPENAI_API_KEY=replace_with_n8n_credential_or_env
OPENAI_MODEL=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cordex_ai_agent
POSTGRES_USER=cordex_agent
POSTGRES_PASSWORD=replace_with_secret_manager_value
POSTGRES_SSL=false

APPROVAL_WEBHOOK_SECRET=replace_with_random_long_secret
APPROVAL_DEFAULT_RECIPIENT=whatsapp:+5500000000000

CORDEX_BACKEND_BASE_URL=https://api.example.com
CORDEX_BACKEND_AGENT_REPLY_PATH=/api/v1/whatsapp/agent/reply
CORDEX_BACKEND_AGENT_CREDENTIAL_NAME=Cordex Backend Agent Service

ALLOWED_DB_TABLES=agent_sessions,agent_messages,agent_memory,agent_tool_calls,agent_approvals,agent_tasks,agent_documents,agent_document_chunks,agent_whatsapp_events
TOOL_HTTP_TIMEOUT_MS=30000
TOOL_MAX_RETRIES=2
